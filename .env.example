# このファイルをコピーして .env を作成してください（.env はコミットしない）。
# cp .env.example .env

# --- セッション ---
# 参加者セッションCookieの署名鍵。本番では必ず長いランダム文字列に変更する。
# 例: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=change-me-to-a-long-random-string

# --- Supabase（プロジェクト作成後に設定。未設定ならインメモリのデモ実装で動く）---
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOi...        # 公開可（クライアント用）
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi... # サーバ専用。絶対にクライアントへ出さない・コミットしない
